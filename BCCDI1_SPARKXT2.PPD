*% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
*% *PCFileName: "BCCF%%%%.PPD"
*% *LanguageEncoding: ISOLatin1
*% *LanguageVersion: English
*% *Manufacturer: "BRCO"
*% *ModelName: "ESKO-CDI-F-%%%%%%%%%%%%%%"
*% *ShortNickName: "ESKO-CDI-F-%%%%%%%%%%%%%%"
*% *NickName: "ESKO-CDI-F-%%%%%%%%%%%%%%"
*% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
*PCFileName: "BCCDI1SP.PPD"
*LanguageEncoding: ISOLatin1
*LanguageVersion: English
*Manufacturer: "ESKO"
*ModelName: "ESKO-CDI-SPARKXT2"
*ShortNickName: "ESKO-CDI-SPARKXT2"
*NickName: "ESKO-CDI-SPARKXT2"

*Product: "(FlexRip)"
*PSVersion: "(3016.102) 0"

*% General Information and Defaults ===============
*InstalledMemory Standard: ""
*FreeVM: "524288000"
*VMOption Standard: "524288000"
*FCacheSize Standard: 0
*%
*LanguageLevel: "3"
*ColorDevice: True
*DefaultColorSpace: CMYK
*VariablePaperSize: True
*%
*FileSystem: True
*?FileSystem: "
    save false
        (%disk?%)
        { currentdevparams dup /Writeable known
            {/Writeable get {pop true} if} {pop} ifelse
        } 10 string /IODevice resourceforall
        {(True)} {(False)} ifelse = flush
    restore"
*End
*%
*Throughput: "1"
*%
*TTRasterizer: Type42
*?TTRasterizer: "42 /FontType resourcestatus {pop pop /Type42} {/None} ifelse = flush"
*%
*Password: "0"
*ExitServer: "count 0 eq
    {false} {true exch startjob} ifelse
    not {(WARNING : Cannot modify initial VM.) =
        (Missing or invalid password.) =
        (Please contact the author of this software.) = flush quit
        } if"
*End
*%
*%
*Reset: "count 0 eq
    {false} {true exch startjob} ifelse
    not {(WARNING : Cannot reset printer.) =
            (Missing or invalid password.) =
            (Please contact the author of this software.) = flush quit
        } if
    systemdict /quit get exec
    (WARNING : Printer Reset Failed.) = flush"
*End

*%
*%=== Film Feed option, combined with InputSlot (PPD 4.3) ===================
*%
*%DefaultOutputOrder: Normal

*OpenUI *InputSlot/Input Slot: PickOne
*OrderDependency: 20 DocumentSetup *InputSlot
*DefaultInputSlot: Cassette
*InputSlot Cassette/Cassette: ""
*?InputSlot: "save (Cassette) = flush restore"
*CloseUI: *InputSlot

*%=========================================================
*% FlexRip Features
*%=========================================================
*cupsFilter: "application/vnd.cups-postscript 0 pstoegps"
*%
*%=========================================================
*% Feature Set: Transformations
*%=========================================================
*%
*OpenGroup: *BCTransformationFeatures/Transformations
*%
*%=========================================================
*% Rotate
*%=========================================================
*%
*OpenUI *BCRotate/Rotate: PickOne
*OrderDependency: 20 DocumentSetup *BCRotate
*DefaultBCRotate: 0
*ParamBCRotate Tag: "<B0>ccw"
*BCRotate 0: "[ { << /DeviceRenderingInfo << /Type 0 /FastRip << /rot 0 >> >> >> setpagedevice } stopped cleartomark"
*BCRotate 90: "[ { << /DeviceRenderingInfo << /Type 0 /FastRip << /rot 1 >> >> >> setpagedevice } stopped cleartomark"
*BCRotate 180: "[ { << /DeviceRenderingInfo << /Type 0 /FastRip << /rot 2 >> >> >> setpagedevice } stopped cleartomark"
*BCRotate 270: "[ { << /DeviceRenderingInfo << /Type 0 /FastRip << /rot 3 >> >> >> setpagedevice } stopped cleartomark"
*?BCRotate: "currentpagedevice
/DeviceRenderingInfo 2 copy known
{ get
  /FastRip 2 copy known
  { get
    /rot 2 copy known
    { get 90 mul}
    { pop pop 0 } ifelse
  }
  { pop pop 0 } ifelse
}
{ pop pop 0 } ifelse
= flush"
*End
*CloseUI: *BCRotate
*%
*%=========================================================
*% Scale
*%=========================================================
*%
*BCOpenUI *BCScale/Scale: DualNumeric
*OrderDependency: 20 DocumentSetup *BCScale
*ParamBCScale Group: "BCTransformationFeatures/Transformations"
*ParamBCScale Default: "100 100"
*ParamBCScale Tag: "% %"
*ParamBCScale Modifier: "V H"
*ParamBCScale Format: "%3.3f %3.3f"
*ParamBCScale Min: "10 10"
*ParamBCScale Max: "1000 1000"
*ParamBCScale InjectAt: Setup
*ParamBCScale Inject: "
% two numeric values expected on top of stack with V & H edits !
100 div 32 string cvs exch 100 div 32 string cvs 2 copy length exch length 2 copy add 1 add string /BCString exch def
pop exch BCString exch 0 exch putinterval dup BCString exch 32 put 1 add exch BCString 3 1 roll putinterval
[ { << /DeviceRenderingInfo << /Type 0 /FastRip << /scale BCString >> >> >> setpagedevice } stopped pop cleartomark"
*End
*?BCScale: "currentpagedevice
/DeviceRenderingInfo 2 copy known
{ get
  /FastRip 2 copy known
  { get
    /scale 2 copy known
    { get }
    { pop pop (100 100) } ifelse
  }
  { pop pop (100 100) } ifelse
}
{ pop pop (100 100) } ifelse
= flush"
*End
*BCCloseUI: *BCScale
*%
*%=========================================================
*% Mirror Print
*%=========================================================
*%
*OpenUI *MirrorPrint/Mirror Print: Boolean
*OrderDependency: 20 DocumentSetup *MirrorPrint
*DefaultMirrorPrint: False
*MirrorPrint True: "<< /MirrorPrint true >> setpagedevice"
*MirrorPrint False: "<< /MirrorPrint false >> setpagedevice"
*?MirrorPrint: "currentpagedevice /MirrorPrint 2 copy known {get {/True} {/False}
ifelse} {pop pop /Unknown} ifelse = flush"
*End
*CloseUI: *MirrorPrint
*%
*%=========================================================
*% Negative Print
*%=========================================================
*%
*OpenUI *NegativePrint/Negative Print: Boolean
*OrderDependency: 20 DocumentSetup *NegativePrint
*DefaultNegativePrint: False
*NegativePrint True: "<< /NegativePrint true >> setpagedevice"
*NegativePrint False: "<< /NegativePrint false >> setpagedevice"
*?NegativePrint: "currentpagedevice /NegativePrint 2 copy known {get {/True} {/False}
ifelse} {pop pop /Unknown} ifelse = flush"
*End
*CloseUI: *NegativePrint
*%
*CloseGroup: *BCTransformationFeatures
*%
*%=========================================================
*% Feature Set: Screening
*%=========================================================
*%
*OpenGroup: *BCScreeningFeatures/Screening
*%
*%=========================================================
*% Screen Type
*%=========================================================
*%
*OpenUI *BCScreening/Screen Type: PickOne
*OrderDependency: 11 DocumentSetup *BCScreening
*DefaultBCScreening: EskoClassic
*BCScreening EskoClassic/Esko Classic (precalculated): "
  [ { << /DeviceRenderingInfo << /Type 0 /FastRip << /rd_screen 1 /dynacell 0 >> >> >> setpagedevice } stopped
  cleartomark"
*End
*BCScreening PostScript/PostScript: "
  [ { << /DeviceRenderingInfo << /Type 0 /FastRip << /rd_screen 2 /dynacell 0 >> >> >> setpagedevice } stopped
  cleartomark"
*End
*BCScreening DynaCell/DynaCell: "
  [ { << /DeviceRenderingInfo << /Type 0 /FastRip << /rd_screen 2 /dynacell 1 >> >> >> setpagedevice } stopped
  cleartomark"
*End
*?BCScreening: "currentpagedevice
/DeviceRenderingInfo 2 copy known
{ get
  /FastRip 2 copy known
  { get
    /rd_screen 2 copy known
    { get dup
      2 eq
      { currentpagedevice /DeviceRenderingInfo get /FastRip get
        /dynacell 2 copy known
        { get add }
        { pop pop } ifelse
      } if
    }
    { pop pop 1 } ifelse
  }
  { pop pop 1 } ifelse
}
{ pop pop 1 } ifelse
dup 1 le
{ /EskoClassic }
{ dup 2 eq
  { /PostScript }
  { /DynaCell } ifelse
} ifelse
exch pop
= flush"
*End
*CloseUI: *BCScreening
