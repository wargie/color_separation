*PageRegion A4.Transverse: "<< /PageSize [595 842] /Orientation 1 >> setpagedevice"
*PageRegion B4: "<< /PageSize [729 1032] /Orientation 0 >> setpagedevice"
*PageRegion B4.Transverse: "<< /PageSize [729 1032] /Orientation 1 >> setpagedevice"
*PageRegion B5: "<< /PageSize [516 729] /Orientation 0 >> setpagedevice"
*PageRegion B5.Transverse: "<< /PageSize [516 729] /Orientation 1 >> setpagedevice"
